<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AvaloniaPortfolioManager.ViewModels"
        xmlns:dto="using:AvaloniaPortfolioManager.Dtos"
        x:Class="AvaloniaPortfolioManager.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="Portfolio Manager"
        Width="1100"
        Height="700"
        Background="White">

    <Window.Styles>
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#C8102E" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>
        <Style Selector="Button.primary:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#A50D26" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style Selector="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>
        <Style Selector="ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="ListBoxItem:selected Border.card">
            <Setter Property="BorderBrush" Value="#C8102E" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <!-- HEADER -->
        <Border Grid.Row="0"
                Background="#C8102E"
                Padding="20,14">
            <TextBlock Text="Portfolio Manager"
                       FontSize="17"
                       FontWeight="SemiBold"
                       Foreground="White" />
        </Border>

        <!-- SEARCH BAR -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Spacing="8"
                    Margin="16,16,16,0">

            <TextBox Width="310"
                     Height="40"
                     PlaceholderText="Search by name or country"
                     Text="{Binding SearchText, Mode=TwoWay}" />

            <Button Content="Search"
                    Classes="primary"
                    Width="90"
                    Height="40"
                    Command="{Binding LoadClientsCommand}" />

            <Button Content="Clear"
                    Width="80"
                    Height="40"
                    Command="{Binding ClearSearchCommand}" />
        </StackPanel>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="2"
              ColumnDefinitions="420,*"
              Margin="16"
              ColumnSpacing="16">

            <!-- LEFT: CLIENT LIST -->
            <ListBox Grid.Column="0"
                     ItemsSource="{Binding Clients}"
                     SelectedItem="{Binding SelectedClient}"
                     Background="Transparent"
                     BorderThickness="0">

                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="dto:ClientSummaryDto">
                        <Border Classes="card"
                                Padding="14"
                                Margin="0,0,0,8"
                                Background="White"
                                BorderBrush="#E5E5E5"
                                BorderThickness="1"
                                CornerRadius="6">

                            <StackPanel Spacing="4">
                                <TextBlock Text="{Binding FullName}"
                                           FontSize="16"
                                           FontWeight="Medium"
                                           Foreground="#1A1A1A" />

                                <TextBlock Text="{Binding Country}"
                                           FontSize="13"
                                           Foreground="#6B6B6B" />

                                <TextBlock Text="{Binding PortfolioCount, StringFormat='Portfolios: {0}'}"
                                           FontSize="13"
                                           Foreground="#6B6B6B" />

                                <TextBlock Text="{Binding TotalMarketValue, StringFormat='Total: {0:N2}'}"
                                           FontSize="14"
                                           Foreground="#C8102E" />
                            </StackPanel>

                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- RIGHT: CLIENT DETAILS -->
            <ScrollViewer Grid.Column="1">
                <StackPanel Spacing="12">

                    <TextBlock Text="CLIENT DETAILS"
                               FontSize="12"
                               Foreground="#6B6B6B"
                               LetterSpacing="1.5" />

                    <TextBlock Text="{Binding SelectedClientDetails.FullName}"
                               FontSize="26"
                               FontWeight="Medium"
                               Foreground="#1A1A1A" />

                    <TextBlock Text="{Binding SelectedClientDetails.Country, StringFormat='Country: {0}'}"
                               FontSize="15"
                               Foreground="#6B6B6B" />

                    <TextBlock Text="{Binding SelectedClientDetails.PortfolioCount, StringFormat='Portfolios: {0}'}"
                               FontSize="15"
                               Foreground="#6B6B6B" />

                    <TextBlock Text="{Binding SelectedClientDetails.TotalMarketValue, StringFormat='Total Market Value: {0:N2}'}"
                               FontSize="18"
                               FontWeight="Medium"
                               Foreground="#C8102E" />

                    <TextBlock Text="Portfolios"
                               FontSize="18"
                               FontWeight="Medium"
                               Foreground="#1A1A1A"
                               Margin="0,12,0,0" />

                    <ItemsControl ItemsSource="{Binding SelectedClientDetails.Portfolios}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="dto:PortfolioDto">
                                <Border Padding="14"
                                        Margin="0,0,0,8"
                                        Background="#FAFAFA"
                                        BorderBrush="#E5E5E5"
                                        BorderThickness="1"
                                        CornerRadius="6">

                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{Binding Name}"
                                                   FontWeight="Medium"
                                                   Foreground="#1A1A1A" />

                                        <TextBlock Text="{Binding Currency, StringFormat='Currency: {0}'}"
                                                   FontSize="13"
                                                   Foreground="#6B6B6B" />

                                        <TextBlock Text="{Binding TotalMarketValue, StringFormat='Market Value: {0:N2}'}"
                                                   FontSize="14"
                                                   Foreground="#C8102E" />
                                    </StackPanel>

                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- STATUS BAR -->
        <Border Grid.Row="3"
                Background="#FAFAFA"
                BorderBrush="#E5E5E5"
                BorderThickness="0,1,0,0"
                Padding="16,8">
            <TextBlock Text="{Binding StatusMessage}"
                       FontSize="13"
                       Foreground="#6B6B6B" />
        </Border>

    </Grid>
</Window>
