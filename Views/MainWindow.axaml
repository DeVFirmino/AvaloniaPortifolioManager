<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AvaloniaPortfolioManager.ViewModels"
        xmlns:dto="using:AvaloniaPortfolioManager.Dtos"
        x:Class="AvaloniaPortfolioManager.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="Portfolio Manager"
        Width="1100"
        Height="700">

    <Grid RowDefinitions="Auto,*,Auto"
          ColumnDefinitions="420,*"
          Margin="12"
          RowSpacing="12"
          ColumnSpacing="12">

        <!-- TOP SEARCH BAR -->
        <StackPanel Grid.Row="0"
                    Grid.ColumnSpan="2"
                    Orientation="Horizontal"
                    Spacing="8">

            <TextBox Width="310"
                     Height="42"
                     PlaceholderText="Search by name or country"
                     Text="{Binding SearchText, Mode=TwoWay}" />

            <Button Content="Search"
                    Width="90"
                    Height="42"
                    Command="{Binding LoadClientsCommand}" />

            <Button Content="Clear"
                    Width="80"
                    Height="42"
                    Command="{Binding ClearSearchCommand}" />
        </StackPanel>

        <!-- LEFT: CLIENT LIST -->
        <Border Grid.Row="1"
                Grid.Column="0"
                Background="#2B2B2B"
                Padding="10">

            <ListBox ItemsSource="{Binding Clients}"
                     SelectedItem="{Binding SelectedClient}"
                     Background="Transparent"
                     BorderThickness="0">

                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="dto:ClientSummaryDto">
                        <Border Padding="10"
                                Margin="0,0,0,8"
                                Background="#3A3A3A"
                                CornerRadius="4">

                            <StackPanel Spacing="4">
                                <TextBlock Text="{Binding FullName}"
                                           FontSize="16"
                                           FontWeight="Bold" />

                                <TextBlock Text="{Binding Country}"
                                           FontSize="13"
                                           Opacity="0.8" />

                                <TextBlock Text="{Binding PortfolioCount, StringFormat='Portfolios: {0}'}"
                                           FontSize="13"
                                           Opacity="0.8" />

                                <TextBlock Text="{Binding TotalMarketValue, StringFormat='Total: {0:N2}'}"
                                           FontSize="13"
                                           FontWeight="SemiBold" />
                            </StackPanel>

                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <!-- RIGHT: CLIENT DETAILS -->
        <Border Grid.Row="1"
                Grid.Column="1"
                Padding="12">

            <StackPanel Spacing="14">

                <TextBlock Text="Select a client to see details"
                           FontSize="18"
                           FontWeight="SemiBold" />

                <TextBlock Text="{Binding SelectedClientDetails.FullName}"
                           FontSize="28"
                           FontWeight="Bold" />

                <TextBlock Text="{Binding SelectedClientDetails.Country, StringFormat='Country: {0}'}"
                           FontSize="15" />

                <TextBlock Text="{Binding SelectedClientDetails.PortfolioCount, StringFormat='Portfolios: {0}'}"
                           FontSize="15" />

                <TextBlock Text="{Binding SelectedClientDetails.TotalMarketValue, StringFormat='Total Market Value: {0:N2}'}"
                           FontSize="15"
                           FontWeight="SemiBold" />

                <TextBlock Text="Portfolios"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Margin="0,16,0,0" />

                <ItemsControl ItemsSource="{Binding SelectedClientDetails.Portfolios}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="dto:PortfolioDto">
                            <Border Padding="10"
                                    Margin="0,0,0,8"
                                    Background="#252525"
                                    CornerRadius="4">

                                <StackPanel Spacing="4">
                                    <TextBlock Text="{Binding Name}"
                                               FontWeight="Bold" />

                                    <TextBlock Text="{Binding Currency, StringFormat='Currency: {0}'}"
                                               FontSize="13" />

                                    <TextBlock Text="{Binding TotalMarketValue, StringFormat='Market Value: {0:N2}'}"
                                               FontSize="13" />
                                </StackPanel>

                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </Border>

        <!-- BOTTOM STATUS -->
        <TextBlock Grid.Row="2"
                   Grid.ColumnSpan="2"
                   Text="{Binding StatusMessage}"
                   FontSize="14" />

    </Grid>
</Window>
